# LLM Provider: "anthropic" (default), "ollama", or "vllm"
LLM_PROVIDER=anthropic

# Anthropic (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama (required when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:20b

# vLLM (required when LLM_PROVIDER=vllm)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=Qwen/Qwen3-Coder-Next
# VLLM_TOOL_CALL_PARSER=qwen3_coder
# VLLM_TENSOR_PARALLEL_SIZE=1
# VLLM_GPU_MEMORY_UTILIZATION=0.85
# VLLM_MAX_MODEL_LEN=16384

# LangSmith tracing (optional)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=cline-agent-manager

# PostgreSQL telemetry database (optional — when set, telemetry and checkpoints use PostgreSQL)
# DATABASE_URL=postgresql://cline:cline@localhost:5432/cline_telemetry

# Local persistence (optional — defaults shown; used as fallback when DATABASE_URL is not set)
CHECKPOINT_DB=./data/checkpoints.db
OUTPUT_DIR=./data/output
LOG_FILE=./data/logs/agent.jsonl
TELEMETRY_FILE=./data/logs/telemetry.log

# LangSmith local fallback — traces saved here when cloud is unreachable
LANGSMITH_FAILED_TRACES_DIR=./data/traces
